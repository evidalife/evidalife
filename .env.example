# Supabase — copy these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — copy these from your Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — from Stripe dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Public site URL (used for Stripe redirect URLs; auto-detected from request in dev)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
